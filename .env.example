# Resend API Key (for Contact Form emails)
# Retrieve from: https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# Gemini API Key (for AI Chatbot widget)
# Retrieve from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token (for live contribution stats)
# Generate from: GitHub Settings > Developer Settings > Personal Access Tokens (classic)
# Scope required: read:user, user:email
GITHUB_TOKEN=your_github_token_here

# Upstash Redis (for Chatbot daily IP rate limiting)
# Retrieve from: https://upstash.com
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Profile Contact Details (Visible in UI components)
NEXT_PUBLIC_EMAIL=your_email@example.com
NEXT_PUBLIC_PHONE=+91 XXXXX XXXXX
